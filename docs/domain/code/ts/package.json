{
  "name": "promptnotes-domain-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Domain model TypeScript type definitions generated from docs/domain/*.md (Phase 10).",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./shared/*": {
      "types": "./src/shared/*.ts",
      "default": "./src/shared/*.ts"
    },
    "./util/*": {
      "types": "./src/util/*.ts",
      "default": "./src/util/*.ts"
    },
    "./capture/*": {
      "types": "./src/capture/*.ts",
      "default": "./src/capture/*.ts"
    },
    "./curate/*": {
      "types": "./src/curate/*.ts",
      "default": "./src/curate/*.ts"
    }
  }
}
