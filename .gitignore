# Nix / direnv
.direnv/
result
result-*

# Rust
target/
.cargo/
.rustup/
**/*.rs.bk
Cargo.lock.bak

# Node / bun
node_modules/
.bun/
.pnpm-store/
.pnpm/
npm-debug.log
pnpm-debug.log
yarn-error.log

# TypeScript build artifacts
dist/
build/
*.tsbuildinfo

# Tauri
# 注: 個別の target/, gen/schemas は promptnotes/src-tauri/.gitignore が処理する。
# Cargo.lock は Tauri アプリ（バイナリ）なのでコミット対象。

# IDE / OS
# .vscode はリポジトリ共有設定だけ追跡、それ以外は無視する。
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
.DS_Store

# Project local
.env.local
*.log
# VCSDD パイプラインの evidence は commit 対象（Phase ゲートで参照される）。
!.vcsdd/features/*/evidence/*.log
# VCSDD Phase 5 verification 成果物も commit 対象。
!.vcsdd/features/*/verification/**/*.log

# MCP
.playwright-mcp/
